# Database
# DATABASE_PATH=data/learning.db

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Raindrop
RAINDROP_API_TOKEN=your-raindrop-token

# Antigravity Tools Proxy (LLM Gateway)
ANTIGRAVITY_API_KEY=sk-antigravity
ANTIGRAVITY_BASE_URL=http://127.0.0.1:8045/v1

# Model Configuration (override defaults)
# MODEL_STAGE_1=gemini-3-pro
# MODEL_STAGE_2=claude-opus-4-6-thinking
# MODEL_DIGEST=gemini-3-pro
# MODEL_WEEKLY=gemini-3-pro

# Fallback Chain (comma-separated, tried in order when primary fails)
# FALLBACK_CHAIN=gemini-3-flash,claude-sonnet-4-5

# Language (vi = Vietnamese, en = English)
LANGUAGE=vi

# Timezone
TZ=Asia/Ho_Chi_Minh

# Camofox Browser (optional — enhanced extraction for Facebook/LinkedIn)
# CAMOFOX_URL=http://localhost:9377
# CAMOFOX_USER_ID=learning-bot
# CAMOFOX_API_KEY=random-string

# Scheduler (daily auto sync + analyze)
SCHEDULE_HOUR=8
SCHEDULE_MINUTE=0
SCHEDULE_ENABLED=true

# ═══════════════════════════════════════════════════════════
# WEB APP (V2) — Next.js + Supabase
# ═══════════════════════════════════════════════════════════

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-database-password

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-default-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key


# Authentication
# Options: "supabase" (Google+email), "totp" (OTP only), "both" (all methods)
AUTH_PROVIDER=both

# Google OAuth (configure in Supabase Dashboard → Auth → Providers → Google)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# TOTP (only needed if AUTH_PROVIDER=totp or AUTH_PROVIDER=both)
# TOTP_SECRET=your-base32-secret
# TOTP_ISSUER=MentorMind

# Next.js
NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXT_PUBLIC_APP_ENV=development
